# Rust
target/
**/*.rs.bk
Cargo.lock

# Node
node_modules/
dist/

# Workspace of upstream example repos (managed by mise src:* tasks).
# Patches against these live in patches/ and ARE checked in.
.src/

# Repo-local bin dir for git-sourced cargo tools (built by `cedar:tools`).
.tools/

# Dev daemon logs (pitchfork etc.).
logs/

# Generated entity-graph artifacts from `cedar:viz` (regenerable).
examples/*-policies/entities.dot
examples/*-policies/entities.svg

# Cloud Code VSCode extension bug (writes to a literal "undefined" path).
undefined/

# OS
.DS_Store
